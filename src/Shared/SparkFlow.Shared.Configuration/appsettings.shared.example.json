{
  "Application": {
    "ApplicationName": "SparkFlow",
    "EnvironmentName": "Development",
    "InstanceName": "Local"
  },
  "Server": {
    "BaseUrl": "https://localhost:5001",
    "RequestTimeoutSeconds": 30,
    "ApiKey": ""
  },
  "LocalApi": {
    "Host": "127.0.0.1",
    "Port": 5271,
    "UseHttps": false,
    "RequestTimeoutSeconds": 15
  },
  "Logging": {
    "MinimumLevel": "Information",
    "LogDirectory": "logs",
    "RollingInterval": "Day",
    "RetainedFileCountLimit": 30,
    "WriteToConsole": true,
    "WriteToDebug": true,
    "WriteToFile": true
  }
}